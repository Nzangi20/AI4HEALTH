# BreastGuard AI - Environment Variables
# Copy this file to .env and fill in your values

# Database (use PostgreSQL URL for production)
DATABASE_URL=sqlite:///./breastguard.db

# JWT Secret Key (use a long random string in production)
SECRET_KEY=breastguard-ai-secret-key-change-in-production-2024

# Admin Credentials
ADMIN_EMAIL=admin@breastguard.local
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=System Admin

# CORS Allowed Origins (comma-separated, use * for development)
ALLOWED_ORIGINS=*
